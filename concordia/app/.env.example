# ── CONCORDIA Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Google AI API Key (REQUIRED) ─────────────────────────────────
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# ── Vertex AI (alternative to API key) ───────────────────────────
# Set to TRUE if using Vertex AI instead of Gemini API
GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Model Selection ──────────────────────────────────────────────
# Text mode (default, fast, reliable):
CONCORDIA_MODEL=gemini-3-flash-preview
# Voice mode (enables live audio):
# CONCORDIA_MODEL=gemini-3-flash-preview-native-audio

# ── Application Settings ─────────────────────────────────────────
# MAX_PARTIES_PER_CASE=6
# HEALTH_THRESHOLD_PARTY=60
# HEALTH_THRESHOLD_RESOLVE=75
# LOG_LEVEL=INFO
# CORS_ORIGINS=*
